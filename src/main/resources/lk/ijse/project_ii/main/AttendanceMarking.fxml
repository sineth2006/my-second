<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.project_ii.viewController.AttendanceMarkingController">
   <children>
      <AnchorPane prefHeight="80.0" prefWidth="712.0" style="-fx-background-color: #1abc9c;">
         <children>
            <Label layoutX="14.0" layoutY="19.0" text="Attendance  Marking" underline="true">
               <font>
                  <Font name="System Bold" size="29.0" />
               </font>
            </Label>
            <Button fx:id="attendance_marking_back_button" layoutX="610.0" layoutY="28.0" mnemonicParsing="false" onAction="#attendance_marking_back_button_OnAction" text="⬅ BACK" />
         </children>
      </AnchorPane>
      <AnchorPane layoutY="87.0" prefHeight="80.0" prefWidth="712.0" style="-fx-background-color: #95a5a6;">
         <children>
            <Label layoutX="14.0" layoutY="6.0" text="Class">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            <ComboBox fx:id="class_combobox" layoutX="14.0" layoutY="33.0" onAction="#class_comboboxOnAction" prefHeight="25.0" prefWidth="182.0" />
            <Button fx:id="attendance_marking_save_attendance_button" layoutX="479.0" layoutY="31.0" mnemonicParsing="false" onAction="#attendance_marking_save_attendance_button_OnAction" prefHeight="27.0" prefWidth="128.0" style="-fx-background-color: #9b59b6;" text="+ Save Attendance" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>
            <Button fx:id="attendance_marking_clean_button" layoutX="618.0" layoutY="31.0" mnemonicParsing="false" onAction="#attendance_marking_clean_button_OnAction" prefHeight="27.0" prefWidth="61.0" style="-fx-background-color: #e67e22;" text="Clean" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>
         </children>
      </AnchorPane>
      <TableView fx:id="attendance_marking_table" layoutY="174.0" onMouseClicked="#attendance_marking_table_clicked" prefHeight="227.0" prefWidth="712.0">
        <columns>
          <TableColumn fx:id="scheduling_id_column" prefWidth="75.0" text="Scheduling ID" />
            <TableColumn fx:id="attendance_id_column" prefWidth="75.0" text="Attendance ID" />
          <TableColumn fx:id="student_id_column" prefWidth="75.0" text="Student ID" />
            <TableColumn fx:id="status_column" prefWidth="75.0" text="Status" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</AnchorPane>
