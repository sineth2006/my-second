<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.project_ii.viewController.CouseManagementController">
   <children>
      <AnchorPane prefHeight="78.0" prefWidth="700.0" style="-fx-background-color: #16a085;">
         <children>
            <Label layoutX="17.0" layoutY="18.0" style="-fx-background-color: #16a085; -fx-background-radius: 20; -fx-border-radius: 20;" text="Course Management" underline="true">
               <font>
                  <Font name="System Bold" size="29.0" />
               </font>
            </Label>
            <Button fx:id="Couse_Management_back_button" layoutX="586.0" layoutY="27.0" mnemonicParsing="false" onAction="#Couse_Management_back_button_OnAction" prefHeight="25.0" prefWidth="81.0" style="-fx-background-color: #7efff5;" text="⬅ Back" textFill="#794343" />
         </children>
      </AnchorPane>
      <Line endX="582.0" layoutX="109.0" layoutY="93.0" startX="-100.0" stroke="#2c2a2a" strokeWidth="3.0" />
      <TextField fx:id="course_id_txtbox" layoutX="24.0" layoutY="114.0" promptText="Course_ID" />
      <TextField fx:id="course_name_txtbox" layoutX="267.0" layoutY="114.0" promptText="Course_Name" />
      <TextField fx:id="course_duration_txtbox" layoutX="512.0" layoutY="114.0" promptText="Course_Duration" />
      <Button fx:id="couse_management_add_button" layoutX="44.0" layoutY="152.0" mnemonicParsing="false" onAction="#Couse_Management_Add_button_OnAction" prefHeight="25.0" prefWidth="94.0" style="-fx-background-color: #ff5252;" text="Add" />
      <Button fx:id="couse_management_update_button" layoutX="301.0" layoutY="152.0" mnemonicParsing="false" onAction="#Couse_Management_Update_button_OnAction" prefHeight="25.0" prefWidth="81.0" style="-fx-background-color: #aaa69d;" text="Update" />
      <Button fx:id="couse_management_delete_button" layoutX="546.0" layoutY="152.0" mnemonicParsing="false" onAction="#Couse_Management_delete_button_OnAction" prefHeight="25.0" prefWidth="81.0" style="-fx-background-color: #227093;" text="🗑 Delete" />
      <TableView fx:id="couse_management_table" layoutY="192.0" onMouseClicked="#couse_management_table_clicked" prefHeight="400.0" prefWidth="700.0">
        <columns>
          <TableColumn fx:id="course_id" prefWidth="75.0" text="Course ID" />
          <TableColumn fx:id="course_name" prefWidth="156.0" text="Course Name" />
            <TableColumn fx:id="course_duration" prefWidth="156.0" text="Couse Duration" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</AnchorPane>
