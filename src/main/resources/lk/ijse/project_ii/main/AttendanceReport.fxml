<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="700.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="lk.ijse.project_ii.viewController.AttendanceReportController">
   <children>
      <AnchorPane layoutY="-8.0" prefHeight="84.0" prefWidth="700.0" style="-fx-background-color: #27ae60;">
         <children>
            <Label layoutX="14.0" layoutY="21.0" text="Attendance Report" underline="true">
               <font>
                  <Font name="System Bold" size="29.0" />
               </font>
            </Label>
            <Button fx:id="attendance_report_back_button" layoutX="618.0" layoutY="30.0" mnemonicParsing="false" onAction="#attendance_report_back_button_OnAction" text="⬅ BACK" />
         </children>
      </AnchorPane>
      <AnchorPane layoutY="84.0" prefHeight="84.0" prefWidth="700.0" style="-fx-background-color: #95a5a6;">
         <children>
            <Label layoutX="14.0" layoutY="6.0" text="Student ID" />
            <ComboBox fx:id="studentId_combobox" layoutX="14.0" layoutY="23.0" prefWidth="150.0" />
            <Label layoutX="177.0" layoutY="6.0" text="Subject ID" />
            <ComboBox fx:id="subjectid_combobox" layoutX="177.0" layoutY="23.0" prefWidth="150.0" />
            <Label layoutX="337.0" layoutY="6.0" text="Date Range" />
            <DatePicker layoutX="330.0" layoutY="23.0" />
            <DatePicker layoutX="330.0" layoutY="51.0" />
            <Button fx:id="attendance_report_clear_button" layoutX="562.0" layoutY="51.0" mnemonicParsing="false" onAction="#attendance_report_clear_button_OnAction" prefHeight="25.0" prefWidth="104.0" style="-fx-background-color: #f39c12;" text="Clear" textFill="#f2f2f2">
               <font>
                  <Font name="System Bold" size="11.0" />
               </font>
            </Button>
            <Button fx:id="attendance_report_generate_button" layoutX="562.0" layoutY="11.0" mnemonicParsing="false" onAction="#attendance_report_generate_button_OnAction" prefHeight="25.0" prefWidth="104.0" style="-fx-background-color: #e74c3c;" text="+ Generate" textFill="#e1d5d5">
               <font>
                  <Font name="System Bold" size="11.0" />
               </font>
            </Button>
         </children>
      </AnchorPane>
      <TableView layoutY="174.0" prefHeight="227.0" prefWidth="701.0">
        <columns>
          <TableColumn prefWidth="75.0" text="Student id" />
          <TableColumn prefWidth="75.0" text="Student Name" />
            <TableColumn prefWidth="75.0" text="Subject" />
            <TableColumn prefWidth="75.0" text="Date Range" />
            <TableColumn prefWidth="75.0" text="Status" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</AnchorPane>
